# Provider mode — controls which set of provider implementations are wired in.
# Demo V1 default = "mock" (all data from src/lib/fixtures, no external APIs).
# Production V1 = "production" (real vendor SDKs behind provider abstractions).
NEXT_PUBLIC_PROVIDER_MODE=mock

# Per-provider override env vars (Story 1.2 introduces these; documented here so
# devs see the full surface). Each is optional and overrides the global mode for
# a single provider — useful for local development against one real vendor while
# everything else stays mocked.
# NEXT_PUBLIC_AR_PROVIDER=mediapipe
# NEXT_PUBLIC_REVIEW_PROVIDER=mock
# NEXT_PUBLIC_AUTH_PROVIDER=mock
# NEXT_PUBLIC_ATTRIBUTION_PROVIDER=mock
# NEXT_PUBLIC_NOTIFICATION_PROVIDER=mock
# NEXT_PUBLIC_BOOKING_HANDOFF_PROVIDER=mock
# NEXT_PUBLIC_SALON_PROVIDER=mock
# NEXT_PUBLIC_BSG_PROVIDER=mock
# NEXT_PUBLIC_CALENDAR_PROVIDER=mock
# NEXT_PUBLIC_EDITORIAL_PROVIDER=mock

# Server-only secrets (Production V1). Never prefixed with NEXT_PUBLIC_.
# Stored in cloud secret manager; rotated per architecture §4 cadence.
# ATTRIBUTION_TOKEN_SECRET=
# DATABASE_URL=postgres://user:password@localhost:5432/sb_tryon
# SALLY_REWARDS_OAUTH_CLIENT_ID=
# SALLY_REWARDS_OAUTH_CLIENT_SECRET=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# SENDGRID_API_KEY=
# CHROMATIC_PROJECT_TOKEN=
