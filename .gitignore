# OS / IDE
.DS_Store
.vscode/
.idea/
*.swp

# Dependencies / build
node_modules/
dist/
build/
*.log

# Secrets
.env
.env.*

# Local AI tooling installations (collaborators install their own)
.agent/
.agents/
.claude/

# BMad runtime — treated like an installed dependency. Collaborators run the
# BMad installer themselves to regenerate _bmad/. Only _bmad/custom/ is
# committed (team-level customizations BMad explicitly designates as portable).
# The nested _bmad/custom/.gitignore handles config.user.toml.
_bmad/*
!_bmad/custom/
